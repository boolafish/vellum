{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vellum",
  "version": "0.1.1",
  "identifier": "com.vellum.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Vellum",
        "width": 900,
        "height": 680,
        "minWidth": 480,
        "minHeight": 360,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "public.app-category.productivity",
    "copyright": "© 2026 Vellum",
    "shortDescription": "A lightweight, fast Markdown editor",
    "longDescription": "A lightweight, fast Markdown editor for macOS built with Tauri.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "txt"],
        "name": "Markdown Document",
        "role": "Editor"
      }
    ]
  }
}
